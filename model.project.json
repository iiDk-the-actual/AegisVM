{
  "name": "Aegis",
  "tree": {
    "$className": "Model",

    "MainModule": {
      "$path": "src/server/MainModule.luau",

      "Aegis": {
        "$path": "src/server/Aegis.luau",
        "Constants": { "$path": "src/server/Aegis/Constants.luau" },
        "Error":     { "$path": "src/server/Aegis/Error.luau" },
        "Lexer":     { "$path": "src/server/Aegis/Lexer.luau" },
        "Parser":    { "$path": "src/server/Aegis/Parser.luau" },
        "Runtime":   { "$path": "src/server/Aegis/Runtime.luau" },
        "Scope":     { "$path": "src/server/Aegis/Scope.luau" },
        "StdLib":    { "$path": "src/server/Aegis/StdLib.luau" },
        "Libraries": {
          "$path": "src/server/Aegis/Libraries.luau",
          "WebRbxmParser": {
            "$path": "src/server/Aegis/Libraries/WebRbxmParser.luau",
            "ScriptTemplate": {
              "$path": "src/server/Aegis/Libraries/WebRbxmParser/ScriptTemplate.server.luau",
              "$properties": { "Enabled": { "Bool": false } }
            },
            "LocalScriptTemplate": {
              "$path": "src/server/Aegis/Libraries/WebRbxmParser/LocalScriptTemplate.client.luau",
              "$properties": { "Enabled": { "Bool": false } }
            },
            "ModuleScriptTemplate": {
              "$path": "src/server/Aegis/Libraries/WebRbxmParser/ModuleScriptTemplate.luau"
            }
          }
        }
      }
    },

    "ThumbnailCamera": { "$path": "src/ThumbnailCamera.rbxmx" }
  }
}
