{
  "name": "rojoproj",
  "tree": {
    "$className": "DataModel",

    "ServerScriptService": {
      "Aegis":
      {
        "$path": "src/server/Aegis.luau",
        "Constants": { "$path": "src/server/Aegis/Constants.luau" },
        "Error":   { "$path": "src/server/Aegis/Error.luau" },
        "Lexer":   { "$path": "src/server/Aegis/Lexer.luau" },
        "Parser":  { "$path": "src/server/Aegis/Parser.luau" },
        "Runtime": { "$path": "src/server/Aegis/Runtime.luau" },
        "Scope":   { "$path": "src/server/Aegis/Scope.luau" },
        "StdLib":  { "$path": "src/server/Aegis/StdLib.luau" },
        "Libraries": {
          "$path": "src/server/Aegis/Libraries.luau",
          "NewScript": {
            "$path": "src/server/Aegis/Libraries/NewScript.luau",
            "ScriptTemplate": {
              "$path": "src/server/Aegis/Libraries/NewScript/ScriptTemplate.server.luau",
              "$properties": { "Disabled": { "Bool": true } }
            },
            "LocalScriptTemplate": {
              "$path": "src/server/Aegis/Libraries/NewScript/LocalScriptTemplate.client.luau",
              "$properties": { "Disabled": { "Bool": true } }
            },
            "ModuleScriptTemplate": {
              "$path": "src/server/Aegis/Libraries/NewScript/ModuleScriptTemplate.luau"
            }
          },
          "WebRbxmParser": {
            "$path": "src/server/Aegis/Libraries/WebRbxmParser.luau"
          },
          "ClientComm": {
            "$path": "src/server/Aegis/Libraries/ClientComm.luau",
            "ClientAgent": {
              "$path": "src/server/Aegis/Libraries/ClientComm/ClientAgent.client.luau",
              "$properties": { "Disabled": { "Bool": true } }
            }
          }
        }
      }
    },

    "Workspace": {
      "ThumbnailCamera": { "$path": "src/ThumbnailCamera.rbxmx" }
    }
  }
}
